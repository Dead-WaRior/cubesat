# ==========================================
# Frontend Dashboard Environment Variables
# (Prefix with VITE_ if used directly in Vite)
# ==========================================

# Dashboard API URL pointing to the backend
VITE_API_URL=http://localhost:8000

# Firebase Configuration for Dashboard
VITE_FIREBASE_API_KEY="AIza...your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"
VITE_FIREBASE_APP_ID="1:1234567890:web:abcdef"
VITE_FIREBASE_MEASUREMENT_ID="G-ABCDEF123"
VITE_FIREBASE_DATABASE_URL="https://your-project-id-default-rtdb.firebaseio.com"

# ==========================================
# Backend / Simulation Environment Variables
# ==========================================

# Redis connection details
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=info
